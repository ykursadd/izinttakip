# PostgreSQL bağlantısı
DATABASE_URL=postgres://username:password@localhost:5432/izinttakip
# Eğer SSL kullanıyorsanız true yapın
DB_SSL=false

# JWT ve SMTP ayarları
JWT_SECRET=super-secret-key
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com
API_BASE_URL=https://izinttakip.onrender.com
